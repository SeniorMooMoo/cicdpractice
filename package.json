{
  "name": "cicdpractice",
  "version": "1.0.0",
  "description": "A practice project for learning CI/CD with GitHub Actions",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "jest --coverage",
    "lint": "eslint src/",
    "build": "node --check src/app.js && node --check src/server.js && echo 'Build check passed'"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  }
}
